---
import ChevronRightIcon from "@heroicons/react/24/outline/ChevronRightIcon";
---

<section class="relative w-full overflow-hidden h-screen mt-[-100px] z-0">
  <img
    src="/img/add-campaing.webp"
    alt="Mundial 2026 UCM"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div
    class="absolute inset-0"
    style="background:linear-gradient(105deg, rgba(0,0,0,0.70) 0%, rgba(0,0,0,0.40) 50%, rgba(0,0,0,0.25) 100%);"
  >
  </div>

  <div
    class="relative z-10 flex flex-col items-center justify-center container-ucm h-screen py-8"
  >
    <div
      class="ac-content max-w-[840px] rounded-[4rem] border border-white/10 backdrop-blur-[2px] bg-radial-[at_50%_50%] from-black/5 to-black/17 to-95% px-10 py-16"
      style="transition:opacity 0.8s ease, transform 0.8s ease;"
    >
      <h2
        class="text-white text-[clamp(1.8rem,4vw,3rem)] leading-none mb-8 tracking-tighter text-center"
      >
        ¿Quieres saber cómo ir al Mundial{""}<br /> 2026 de la mano de la UCM?
      </h2>
      <div
        class="flex flex-wrap items-center justify-between gap-4 max-w-[640px] mx-auto"
      >
        <a
          href="#contacto"
          class="btn-secondary w-[260px] text-center flex items-center justify-center gap-2"
          ><span>Conocer más</span>
          <ChevronRightIcon width={18} height={18} /></a
        >
        <a
          href="#contacto"
          class="btn-primary w-[260px] text-center flex items-center justify-center gap-2"
          ><span>Convertirme en socio</span>
          <ChevronRightIcon width={18} height={18} /></a
        >
      </div>
    </div>
  </div>

  <div
    class="absolute top-1/2 right-0 -translate-y-1/2 hidden lg:block"
    style="width:320px;height:320px;border:2px solid rgba(206,162,74,0.25);border-radius:50%;margin-right:-80px;"
  >
  </div>
  <div
    class="absolute top-1/2 right-0 -translate-y-1/2 hidden lg:block"
    style="width:220px;height:220px;border:2px solid rgba(206,162,74,0.15);border-radius:50%;margin-right:-30px;"
  >
  </div>
</section>

<script>
  const el = document.querySelector(".ac-content") as HTMLElement | null;
  if (el) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
          obs.disconnect();
        }
      },
      { threshold: 0.12 },
    );
    obs.observe(el);
  }
</script>
