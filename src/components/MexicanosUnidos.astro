---
// Laterals per side. They reveal in pairs from the center outward, building
// the zig‑zag from a single central "M" to a full-width band.
const SIDE = 7;
const leftIds = Array.from({ length: SIDE }, (_, k) => SIDE - k); // 7..1 (outer→inner)
const rightIds = Array.from({ length: SIDE }, (_, k) => k + 1); // 1..7 (inner→outer)
// Laterals are absolutely centered (stacked behind the central M) and fan out
// left/right as they reveal.
const imgClass =
  "mu-lateral hidden absolute left-1/2 top-1/2 h-auto max-w-[70px] md:max-w-[190px] will-change-transform";
---

<section id="mu-section" class="relative w-full h-auto md:h-[220vh]">
  <!-- Sticky stage: pins the band in the viewport so the page cannot reach the
       next section until the scrub through the tall track has filled it. -->
  <div
    class="mu-stage sticky top-0 h-screen flex flex-col justify-center overflow-hidden"
  >
    <div class="container-ucm flex items-center gap-5">
      <div
        class="mu-line flex-1 h-px"
        style="background:linear-gradient(to right, transparent, #CEA24A60);"
      >
      </div>

      <div class="mu-row relative flex items-center justify-center text-center">
        {
          leftIds.map((n) => (
            <img
              id={`mu-lateral-izq-${n}`}
              class={imgClass + "transition-all duration-300 ease-in-out"}
              src="/img/M_lateral.svg"
              alt="Mexicanos Unidos"
            />
          ))
        }

        <img
          class="mu-central relative z-[100] block h-auto shrink-0 max-w-[70px] md:max-w-[190px]"
          src="/img/M_central.svg"
          alt="Mexicanos Unidos"
        />

        {
          rightIds.map((n) => (
            <img
              id={`mu-lateral-der-${n}`}
              class={imgClass + "transition-all duration-300 ease-in-out"}
              src="/img/M_lateral.svg"
              alt="Mexicanos Unidos"
            />
          ))
        }
      </div>

      <div
        class="mu-line flex-1 h-px"
        style="background:linear-gradient(to left, transparent, #CEA24A60);"
      >
      </div>
    </div>

    <!-- Caption under the central M: "Mexicanos" shows from the start, "Unidos"
         fades in once the band is full (and fades out on the way back). -->
    <p
      class="mu-caption mt-12 w-full text-center font-bold uppercase tracking-[0.15em] text-[#0A0B1E]"
      style="font-size:20px;"
    >
      <span
        class="mu-mex hidden font-[600] transition-all duration-300 ease-in-out"
        >Mexicanos</span
      >
      <span
        class="mu-unidos hidden font-[600] transition-all duration-300 ease-in-out"
        >Unidos</span
      >
    </p>
  </div>
</section>

<script>
  import { scroll } from "motion";

  const section = document.getElementById("mu-section");
  const row = section?.querySelector<HTMLElement>(".mu-row");
  const central = section?.querySelector<HTMLElement>(".mu-central");
  const mexEl = section?.querySelector<HTMLElement>(".mu-mex");
  const uniEl = section?.querySelector<HTMLElement>(".mu-unidos");

  if (section && row && central) {
    // The section is pinned: you can't reach the next section until the band is
    // full. As you scroll DOWN through the pin the laterals reveal (remove
    // `hidden`, add `block`) one pair at a time from the centre outward; scroll
    // UP hides them again, dropping the outermost ("las últimas") first.
    // Flip INVERT to swap the scroll polarity.
    const INVERT = false;
    // Band reaches "full" at this fraction of the pin, then holds full for the
    // rest of the scroll so it's clearly complete before the next section.
    const FILL_AT = 0.85;

    // Build the two sides from DOM order, each ordered nearest-center → outward,
    // so it stays correct regardless of ids or count.
    const kids = Array.from(row.children) as HTMLElement[];
    const ci = kids.indexOf(central);
    const isLat = (el: HTMLElement) => el.classList.contains("mu-lateral");
    const left = kids.slice(0, ci).filter(isLat).reverse(); // inner → outer
    const right = kids.slice(ci + 1).filter(isLat); // inner → outer
    const PAIRS = Math.min(left.length, right.length);

    const clamp = (v: number, a = 0, b = 1) => Math.min(b, Math.max(a, v));
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    // Stack the laterals behind the central M (which sits at z-100); inner
    // laterals stay above outer ones for a clean overlapping fan.
    left.forEach((img, i) => (img.style.zIndex = `${90 - i}`));
    right.forEach((img, i) => (img.style.zIndex = `${90 - i}`));

    // Per-image fixed size + step between M's, recomputed on resize so each M
    // keeps the same size (≤180px desktop / ≤70px mobile) and interlocks.
    let unit = 0;
    let step = 0;
    function measure() {
      unit = central!.getBoundingClientRect().width || 180;
      step = unit * 0.78; // horizontal advance per M (≈ width minus overlap)
      [...left, ...right].forEach((img) => (img.style.width = `${unit}px`));
    }

    // Reveal/hide one lateral, scrubbed by `t` (0 = stacked & hidden behind the
    // central M, 1 = fanned out to its final spot). `i` is its distance from
    // the centre (0 = innermost); `side` is -1 left / +1 right.
    function setLateral(img: HTMLElement, side: -1 | 1, i: number, t: number) {
      if (t <= 0.001) {
        img.classList.add("hidden");
        img.classList.remove("block");
        return;
      }
      img.classList.remove("hidden");
      img.classList.add("block");

      const e = easeOut(t);
      const x = side * (i + 1) * step * e; // slide from centre (0) → final
      img.style.opacity = `${e}`;
      img.style.transform = `translate(-50%, -50%) translateX(${x}px) scale(${lerp(0.7, 1, e)})`;
    }

    // Map a value across [a,b], clamped, with an ease for a soft reveal.
    const fade = (v: number, a: number, b: number) =>
      easeOut(clamp((v - a) / (b - a)));

    // Reveal a caption word with a slide-to-the-left (instead of a plain fade):
    // it starts offset to the right and slides into place as `t` goes 0 → 1.
    // While hidden it's display:none (not just opacity) so it reserves no space
    // and the visible word(s) stay centred.
    const SLIDE = 40; // px travelled leftward into place
    const setWord = (el: HTMLElement, t: number) => {
      if (t <= 0.001) {
        el.classList.add("hidden");
        el.classList.remove("inline-block");
        return;
      }
      el.classList.remove("hidden");
      el.classList.add("inline-block");
      el.style.opacity = `${t}`;
      el.style.transform = `translateX(${lerp(SLIDE, 0, t)}px)`;
    };

    // Pure function of revealed-progress (0 = only central, 1 = full band).
    function render(effect: number) {
      const reveal = effect * PAIRS; // how many pairs are (partly) shown
      for (let i = 0; i < PAIRS; i++) {
        const t = clamp(reveal - i); // each pair gets its own 0..1 window
        setLateral(left[i], -1, i, t);
        setLateral(right[i], 1, i, t);
      }
      // "Mexicanos" slides in at the start; "Unidos" slides in only once the
      // band has finished filling (and slides back out as it empties).
      if (mexEl) setWord(mexEl, fade(effect, 0, 0.1));
      if (uniEl) setWord(uniEl, fade(effect, 0.9, 1));
    }

    // --- silky smoothing: ease the rendered value toward the scroll target ---
    let target = 0;
    let current = 0;
    let rafId = 0;
    function tick() {
      current += (target - current) * 0.14;
      if (Math.abs(target - current) < 0.0008) current = target;
      render(current);
      rafId = current === target ? 0 : requestAnimationFrame(tick);
    }
    function schedule() {
      if (!rafId) rafId = requestAnimationFrame(tick);
    }

    measure();
    render(0);
    window.addEventListener("resize", () => {
      measure();
      render(current);
    });

    // Scrub across the pinned track: progress is 0 when the track's top hits
    // the viewport top (band empty) and 1 when its bottom hits the viewport
    // bottom (band full) — i.e. only when filled does the page move on.
    scroll(
      (p: number) => {
        const prog = clamp(p / FILL_AT);
        target = INVERT ? 1 - prog : prog;
        schedule();
      },
      { target: section, offset: ["start start", "end end"] },
    );
  }
</script>
