---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<!-- Backdrop -->
<div
  id={id}
  class="ucm-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${id}-title`}
  hidden
>
  <div class="ucm-modal__backdrop" data-modal-close></div>

  <div class="ucm-modal__panel">
    <!-- Close button -->
    <button class="ucm-modal__close" aria-label="Cerrar" data-modal-close>
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Form content injected by consumer -->
    <slot />
  </div>
</div>

<style>
  .ucm-modal {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .ucm-modal[hidden] {
    display: none;
  }

  .ucm-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 11, 30, 0.62);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
    /*animation: modal-fade-in 0.22s ease;*/
  }

  .ucm-modal__panel {
    position: relative;
    background: #ffffff;
    border-radius: 2rem;
    width: 100%;
    max-width: 640px;
    max-height: 92vh;
    overflow-y: auto;
    padding: 3rem 3rem 2.5rem;
    box-shadow: 0 32px 80px rgba(10, 11, 30, 0.22);
    /*animation: modal-slide-up 0.28s cubic-bezier(0.22, 1, 0.36, 1);*/
  }

  @media (max-width: 600px) {
    .ucm-modal__panel {
      padding: 2rem 1.5rem 2rem;
      border-radius: 1.5rem;
    }
  }

  .ucm-modal__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #f0ede8;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0a0b1e;
    transition:
      background 0.2s ease,
      color 0.2s ease;
    flex-shrink: 0;
  }

  .ucm-modal__close:hover {
    background: #0a0b1e;
    color: #ffffff;
  }

  @keyframes modal-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes modal-slide-up {
    from {
      opacity: 0;
      transform: translateY(28px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  // Generic open / close logic reused by all modals
  document.addEventListener("DOMContentLoaded", () => {
    // Open triggers: <button data-open-modal="modal-id">
    document
      .querySelectorAll<HTMLElement>("[data-open-modal]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const target = btn.dataset.openModal!;
          const modal = document.getElementById(target);
          if (!modal) return;
          modal.removeAttribute("hidden");
          //document.body.style.overflow = "hidden";
          // Focus first focusable element — preventScroll stops the browser
          // from scrolling the page to bring the focused field into view.
          const first = modal.querySelector<HTMLElement>(
            "input, select, textarea, button:not([data-modal-close])",
          );
          first?.focus({ preventScroll: true });
        });
      });

    // Close triggers: backdrop + close button
    document
      .querySelectorAll<HTMLElement>("[data-modal-close]")
      .forEach((el) => {
        el.addEventListener("click", () => {
          const modal = el.closest(".ucm-modal") as HTMLElement | null;
          if (!modal) return;
          modal.setAttribute("hidden", "");
          //document.body.style.overflow = "";
        });
      });

    // Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      document
        .querySelectorAll<HTMLElement>(".ucm-modal:not([hidden])")
        .forEach((modal) => {
          modal.setAttribute("hidden", "");
          //document.body.style.overflow = "";
        });
    });
  });
</script>
