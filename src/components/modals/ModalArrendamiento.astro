---
import FormModal from "./FormModal.astro";
---

<FormModal id="modal-arrendamiento">
  <div class="mf-header">
    <h2 id="modal-arrendamiento-title" class="mf-title">Arrendamiento Puro</h2>
  </div>

  <form class="mf-form" name="modal-arrendamiento" method="POST" novalidate>
    <!-- Nombre Completo -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="arr-nombre">Nombre completo</label>
      <input
        class="mf-input"
        type="text"
        id="arr-nombre"
        name="nombre"
        autocomplete="name"
        required
      />
    </div>

    <!-- Empresa + Teléfono -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="arr-empresa">Empresa</label>
        <input
          class="mf-input"
          type="text"
          id="arr-empresa"
          name="empresa"
          autocomplete="organization"
          required
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="arr-telefono">Teléfono</label>
        <input
          class="mf-input"
          type="tel"
          id="arr-telefono"
          name="telefono"
          autocomplete="tel"
          required
        />
      </div>
    </div>

    <!-- Correo + Monto -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="arr-correo">Correo</label>
        <input
          class="mf-input"
          type="email"
          id="arr-correo"
          name="correo"
          autocomplete="email"
          required
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="arr-valor">Valor aproximado del bien</label>
        <input
          class="mf-input"
          type="text"
          id="arr-valor"
          name="valor"
          placeholder="Ej. $800,000"
        />
      </div>
    </div>

    <!-- ¿Qué tipo de bien? -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="arr-tipo">¿Qué tipo de bien deseas arrendar?</label>
      <div class="mf-select-wrap">
        <select class="mf-select" id="arr-tipo" name="tipo" required>
          <option value="" disabled selected></option>
          <option value="vehiculo">Vehículo de carga / flotilla</option>
          <option value="maquinaria">Maquinaria y equipo</option>
          <option value="tecnologia">Tecnología / cómputo</option>
          <option value="medico">Equipo médico</option>
          <option value="otro">Otro</option>
        </select>
        <svg class="mf-select-icon" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </div>

    <!-- Mensaje -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="arr-mensaje">Mensaje</label>
      <textarea
        class="mf-textarea"
        id="arr-mensaje"
        name="mensaje"
        rows="4"
      ></textarea>
    </div>

    <div class="mf-footer">
      <button type="submit" class="mf-submit btn-primary">
        Enviar solicitud
      </button>
    </div>
  </form>
</FormModal>
