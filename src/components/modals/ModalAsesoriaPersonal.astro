---
import FormModal from "./FormModal.astro";
---

<FormModal id="modal-asesoria-personal">
  <div class="mf-header">
    <h2 id="modal-asesoria-personal-title" class="mf-title">Asesoría Personalizada</h2>
    <p class="mf-subtitle">Un asesor UCM te contactará para guiarte sin compromiso</p>
  </div>

  <form class="mf-form" name="modal-asesoria-personal" method="POST" novalidate>
    <!-- Nombre Completo -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ase-nombre">Nombre completo</label>
      <input
        class="mf-input"
        type="text"
        id="ase-nombre"
        name="nombre"
        autocomplete="name"
        required
      />
    </div>

    <!-- Empresa (opcional) -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ase-empresa">Empresa <span class="mf-optional">(opcional)</span></label>
      <input
        class="mf-input"
        type="text"
        id="ase-empresa"
        name="empresa"
        autocomplete="organization"
      />
    </div>

    <!-- Correo + Teléfono -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="ase-correo">Correo</label>
        <input
          class="mf-input"
          type="email"
          id="ase-correo"
          name="correo"
          autocomplete="email"
          required
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="ase-telefono">Teléfono</label>
        <input
          class="mf-input"
          type="tel"
          id="ase-telefono"
          name="telefono"
          autocomplete="tel"
          required
        />
      </div>
    </div>

    <!-- ¿En qué área necesitas asesoría? -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ase-area">¿En qué área necesitas asesoría?</label>
      <div class="mf-select-wrap">
        <select class="mf-select" id="ase-area" name="area" required>
          <option value="" disabled selected></option>
          <option value="inversiones">Inversiones y rendimientos</option>
          <option value="credito">Crédito empresarial o personal</option>
          <option value="arrendamiento">Arrendamiento puro</option>
          <option value="planeacion">Planeación financiera</option>
          <option value="membresia">Membresía UCM</option>
          <option value="otro">Otro</option>
        </select>
        <svg class="mf-select-icon" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </div>

    <!-- Mensaje -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ase-mensaje">¿Cómo podemos ayudarte?</label>
      <textarea
        class="mf-textarea"
        id="ase-mensaje"
        name="mensaje"
        rows="4"
        placeholder="Cuéntanos brevemente tu situación o necesidad..."
      ></textarea>
    </div>

    <div class="mf-footer">
      <button type="submit" class="mf-submit btn-primary">
        Solicitar asesoría
      </button>
    </div>
  </form>
</FormModal>
