---
import FormModal from "./FormModal.astro";
---

<FormModal id="modal-credito-empresarial">
  <div class="mf-header">
    <h2 id="modal-credito-empresarial-title" class="mf-title">Crédito Empresarial</h2>
  </div>

  <form class="mf-form" name="modal-credito-empresarial" method="POST" novalidate>
    <!-- Nombre Completo -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ce-nombre">Nombre completo</label>
      <input
        class="mf-input"
        type="text"
        id="ce-nombre"
        name="nombre"
        autocomplete="name"
        required
      />
    </div>

    <!-- Empresa + Teléfono -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="ce-empresa">Empresa</label>
        <input
          class="mf-input"
          type="text"
          id="ce-empresa"
          name="empresa"
          autocomplete="organization"
          required
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="ce-telefono">Teléfono</label>
        <input
          class="mf-input"
          type="tel"
          id="ce-telefono"
          name="telefono"
          autocomplete="tel"
          required
        />
      </div>
    </div>

    <!-- Monto + Correo -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="ce-monto">Monto aproximado</label>
        <input
          class="mf-input"
          type="text"
          id="ce-monto"
          name="monto"
          placeholder="Ej. $1,000,000"
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="ce-correo">Correo</label>
        <input
          class="mf-input"
          type="email"
          id="ce-correo"
          name="correo"
          autocomplete="email"
          required
        />
      </div>
    </div>

    <!-- ¿Qué tipo de financiamiento? -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ce-financiamiento">¿Qué tipo de financiamiento necesitas?</label>
      <div class="mf-select-wrap">
        <select class="mf-select" id="ce-financiamiento" name="financiamiento" required>
          <option value="" disabled selected></option>
          <option value="capital-trabajo">Capital de trabajo</option>
          <option value="expansion">Expansión / apertura de sucursal</option>
          <option value="equipo">Adquisición de equipo</option>
          <option value="inmueble">Compra de inmueble</option>
          <option value="refinanciamiento">Refinanciamiento de deuda</option>
          <option value="otro">Otro</option>
        </select>
        <svg class="mf-select-icon" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </div>

    <!-- Mensaje -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="ce-mensaje">Mensaje</label>
      <textarea
        class="mf-textarea"
        id="ce-mensaje"
        name="mensaje"
        rows="4"
      ></textarea>
    </div>

    <div class="mf-footer">
      <button type="submit" class="mf-submit btn-primary">
        Enviar solicitud
      </button>
    </div>
  </form>
</FormModal>
