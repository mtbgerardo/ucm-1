---
import FormModal from "./FormModal.astro";
---

<FormModal id="modal-inversiones">
  <div class="mf-header">
    <h2 id="modal-inversiones-title" class="mf-title">Inversiones</h2>
  </div>

  <form class="mf-form" name="modal-inversiones" method="POST" novalidate>
    <!-- Nombre Completo -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="inv-nombre">Nombre completo</label>
      <input
        class="mf-input"
        type="text"
        id="inv-nombre"
        name="nombre"
        autocomplete="name"
        required
      />
    </div>

    <!-- Empresa (opcional) -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="inv-empresa">Empresa <span class="mf-optional">(opcional)</span></label>
      <input
        class="mf-input"
        type="text"
        id="inv-empresa"
        name="empresa"
        autocomplete="organization"
      />
    </div>

    <!-- Correo + Teléfono -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="inv-correo">Correo</label>
        <input
          class="mf-input"
          type="email"
          id="inv-correo"
          name="correo"
          autocomplete="email"
          required
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="inv-telefono">Teléfono</label>
        <input
          class="mf-input"
          type="tel"
          id="inv-telefono"
          name="telefono"
          autocomplete="tel"
          required
        />
      </div>
    </div>

    <!-- Monto + ¿Qué buscas? -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="inv-monto">Monto aproximado a invertir</label>
        <input
          class="mf-input"
          type="text"
          id="inv-monto"
          name="monto"
          placeholder="Ej. $500,000"
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="inv-objetivo">¿Qué buscas principalmente?</label>
        <div class="mf-select-wrap">
          <select class="mf-select" id="inv-objetivo" name="objetivo" required>
            <option value="" disabled selected></option>
            <option value="rendimiento">Mayor rendimiento</option>
            <option value="seguridad">Seguridad y estabilidad</option>
            <option value="liquidez">Liquidez</option>
            <option value="diversificacion">Diversificación</option>
            <option value="otro">Otro</option>
          </select>
          <svg class="mf-select-icon" width="16" height="16" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Mensaje -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="inv-mensaje">Mensaje</label>
      <textarea
        class="mf-textarea"
        id="inv-mensaje"
        name="mensaje"
        rows="4"
      ></textarea>
    </div>

    <div class="mf-footer">
      <button type="submit" class="mf-submit btn-primary">
        Enviar solicitud
      </button>
    </div>
  </form>
</FormModal>
