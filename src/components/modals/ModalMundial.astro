---
import FormModal from "./FormModal.astro";
---

<FormModal id="modal-mundial">
  <div class="mf-header">
    <h2 id="modal-mundial-title" class="mf-title">Quiero ir al Mundial</h2>
    <p class="mf-subtitle">Promoción válida únicamente para socios UCM</p>
  </div>

  <form class="mf-form" name="modal-mundial" method="POST" novalidate>
    <!-- Nombre Completo -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="mun-nombre">Nombre completo</label>
      <input
        class="mf-input"
        type="text"
        id="mun-nombre"
        name="nombre"
        autocomplete="name"
        required
      />
    </div>

    <!-- Empresa (opcional) -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="mun-empresa">Empresa <span class="mf-optional">(opcional)</span></label>
      <input
        class="mf-input"
        type="text"
        id="mun-empresa"
        name="empresa"
        autocomplete="organization"
      />
    </div>

    <!-- Correo + Teléfono -->
    <div class="mf-row">
      <div class="mf-field">
        <label class="mf-label" for="mun-correo">Correo</label>
        <input
          class="mf-input"
          type="email"
          id="mun-correo"
          name="correo"
          autocomplete="email"
          required
        />
      </div>
      <div class="mf-field">
        <label class="mf-label" for="mun-telefono">Teléfono</label>
        <input
          class="mf-input"
          type="tel"
          id="mun-telefono"
          name="telefono"
          autocomplete="tel"
          required
        />
      </div>
    </div>

    <!-- Monto aproximado a invertir -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="mun-monto">Monto aproximado a invertir</label>
      <input
        class="mf-input"
        type="text"
        id="mun-monto"
        name="monto"
        placeholder="Ej. $500,000"
      />
    </div>

    <!-- Mensaje -->
    <div class="mf-field mf-field--full">
      <label class="mf-label" for="mun-mensaje">Mensaje</label>
      <textarea
        class="mf-textarea"
        id="mun-mensaje"
        name="mensaje"
        rows="4"
      ></textarea>
    </div>

    <div class="mf-footer">
      <button type="submit" class="mf-submit btn-primary">
        Enviar solicitud
      </button>
    </div>
  </form>
</FormModal>
