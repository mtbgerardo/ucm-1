---
interface Props {
  /** Small label above the headline (e.g. "¿Quiénes Somos?") */
  title?: string;
  /** Main headline HTML string. Use <br /> and <span> as needed. */
  subtitle?: string;
  /** Array of body paragraphs rendered in order */
  paragraphs: string[];
  /** Optional list of bullet-point items rendered with a gold checkmark */
  bulletPoints?: string[];
  /** Image source path */
  imageSrc: string;
  /** Image alt text */
  imageAlt: string;
  /** Optional CTA label. If omitted the button is not rendered. */
  ctaLabel?: string;
  /** Optional CTA href */
  ctaHref?: string;
  /** Optional CTA target */
  ctaTarget?: string;
  /**
   * When false (default) the image column is on the LEFT and text is on the RIGHT.
   * When true the image column moves to the RIGHT and text is on the LEFT.
   */
  imageRight?: boolean;
}

const {
  title,
  subtitle,
  paragraphs,
  bulletPoints,
  imageSrc,
  imageAlt,
  ctaLabel,
  ctaHref = "#",
  ctaTarget = "_self",
  imageRight = false,
} = Astro.props;

// Unique class suffix so multiple instances on the same page each get their own observer
const uid = `bit-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class={`grid md:grid-cols-2 gap-16 items-center ${imageRight ? "md:[&>:first-child]:order-2" : ""}`}
>
  <div class="relative">
    <div
      class="overflow-hidden rounded-2xl w-full h-max-[800px] rounded-[4rem]"
    >
      <img
        src={imageSrc}
        alt={imageAlt}
        class="w-full h-full object-cover"
        style="transition:transform 0.6s ease;"
        onmouseover="this.style.transform='scale(1.04)'"
        onmouseout="this.style.transform='scale(1)'"
      />
    </div>
  </div>

  <div
    class={`bit-content ${uid}`}
    style="opacity:0; transform:translateY(30px); transition:opacity 0.7s ease, transform 0.7s ease;"
  >
    <p class="tracking-tight font-[500] text-sm uppercase mb-3">
      {title}
    </p>
    <h2
      class="font-medium text-[clamp(1.8rem,3.5vw,2.90rem)] text-shadow-lg text-[#0A0B1E] tracking-tighter leading-none mb-8"
      set:html={subtitle}
    />
    {
      paragraphs.map((p) => (
        <p class="text-[#0A0B1E] leading-[1.75] mb-8 text-lg">{p}</p>
      ))
    }
    {
      bulletPoints && bulletPoints.length > 0 && (
        <div class="flex flex-col gap-3 mb-16">
          {bulletPoints.map((item) => (
            <div class="flex items-start gap-3">
              <div
                class="mt-1 shrink-0 w-4 h-4 rounded-full flex items-center justify-center"
                style="background:#CEA24A;"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="white"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
              <p style="color:#0A0B1E; font-size:0.875rem; line-height:1.5;">
                {item}
              </p>
            </div>
          ))}
        </div>
      )
    }
    {
      ctaLabel && (
        <a
          href={ctaHref}
          class="btn-primary"
          target={ctaTarget}
          rel={ctaTarget === "_blank" ? "noopener noreferrer" : ""}
        >
          {ctaLabel}
        </a>
      )
    }
  </div>
</div>

<script define:vars={{ uid }}>
  const el = document.querySelector(`.${uid}`);
  if (el) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
          obs.disconnect();
        }
      },
      { threshold: 0.15 },
    );
    obs.observe(el);
  }
</script>
