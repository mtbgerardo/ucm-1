---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ModalAsesoriaPersonal from "@/components/modals/ModalAsesoriaPersonal.astro";
import ModalInversiones from "@/components/modals/ModalInversiones.astro";
import ModalArrendamiento from "@/components/modals/ModalArrendamiento.astro";
import ModalCreditoEmpresarial from "@/components/modals/ModalCreditoEmpresarial.astro";
import ModalMundial from "@/components/modals/ModalMundial.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "UCM — Unión de Crédito Mexicano | Invierte con respaldo",
  description = "Más de 31 años cuidando y multiplicando el patrimonio de familias mexicanas. Inversiones, crédito y ahorro con transparencia y solidez.",
  image = "/img/hero.webp",
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baskervville:ital@0;1&family=Poppins:wght@100;200;300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <ModalArrendamiento />
    <ModalAsesoriaPersonal />
    <ModalCreditoEmpresarial />
    <ModalInversiones />
    <ModalMundial />
  </body>
</html>
