---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import MexicanosUnidos from "../components/MexicanosUnidos.astro";
import QuienesSomos from "../components/QuienesSomos.astro";
import ThirtyOneYears from "../components/ThirtyOneYears.astro";
import ClientLogos from "../components/ClientLogos";
import PorQueConfiar from "../components/PorQueConfiar.astro";
import QueHacemos from "../components/QueHacemos";
import Reviews from "../components/Reviews";
import AddCampaign from "../components/AddCampaign.astro";
import SeSocio from "../components/SeSocio.astro";
---

<Layout>
  <Hero imageSrc="/img/hero.webp" />
  <MexicanosUnidos />
  <QuienesSomos />
  <ThirtyOneYears />
  <ClientLogos client:load />
  <PorQueConfiar />
  <QueHacemos client:visible />
  <Reviews client:visible />
  <AddCampaign />
  <SeSocio />
</Layout>
